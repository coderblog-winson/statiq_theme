
Title: Tableware
---
@{
    Layout = "_Layout.cshtml";
}

<!-- Banner -->
<section id="banner">
    <div class="content">
        <header>
            <h1>Discover the Perfect<br />Tableware</h1>
            <p>Your ultimate guide to dining aesthetics and dinnerware reviews.</p>
        </header>
        <p>Whether you are looking for the best bone china for a wedding gift, or durable stoneware for daily use, our
            AI-assisted reviews and buying guides cover it all.</p>
            <ul class="actions">
                <li><a href="/posts/buying-guides" class="button big">Read Buying Guides</a>
                </li>
            </ul>
        </div>
        <span class="image object">
            <img src="/images/tableware_index.webp" alt="" />
        </span>
    </section>

    <!-- Section -->
    <section>
        <header class="major">
            <h2>Why trust us?</h2>
        </header>
        <div class="features">
            <article>
                <span class="icon fa-gem"></span>
                <div class="content">
                    <h3>Curated Quality</h3>
                    <p>We select only the best rated products from thousands of options.</p>
                </div>
            </article>
            <article>
                <span class="icon solid fa-paper-plane"></span>
                <div class="content">
                    <h3>Data Driven</h3>
                    <p>Our reviews are based on analyzing thousands of user feedbacks.</p>
                </div>
            </article>
            <article>
                <span class="icon solid fa-rocket"></span>
                <div class="content">
                    <h3>Updated Weekly</h3>
                    <p>Prices and stocks are updated regularly to ensure availability.</p>
                </div>
            </article>
            <article>
                <span class="icon solid fa-signal"></span>
                <div class="content">
                    <h3>Price Tracking</h3>
                    <p>We help you find the best deals on Amazon and other retailers.</p>
                </div>
            </article>
        </div>
    </section>

    <!-- Section -->
    <section>
        <header class="major">
            <h2>Recent Reviews & Guides</h2>
        </header>
        <div class="posts">
            @{
                // 1. Scan all output pages
                // 2. Filter condition: source file not null + source file path contains "posts" + must be .md file (exclude index.cshtml)
                // 3. Sort: use Get<DateTime> to sort by date in descending order
                var recentPosts = OutputPages
                    .Where(x => x.Source != null
                             && x.Source.ToString().Contains("posts")
                             && x.Source.Extension == ".md"
                             && x.ContainsKey("Date"))
                    .OrderByDescending(x => x.Get<DateTime>("Date"))
                    .Take(6);
            }

            @foreach (var doc in recentPosts)
            {
                <article>
                    <a href="@doc.GetLink()" class="image">
                        <img src="@(doc.GetString("Image") ?? "/images/pic01.jpg")" alt="@doc.GetTitle()" />
                    </a>
                    <h3>@doc.GetTitle()</h3>

                    <p>@doc.GetString("Description")</p>

                    <ul class="actions">
                        <li><a href="@doc.GetLink()" class="button">Read Review</a></li>
                    </ul>
                </article>
            }
        </div>
    </section>